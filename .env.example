# Password matches docker-compose.yml (POSTGRES_PASSWORD: omniagent)
DATABASE_URL=postgres://omniagent:omniagent@postgres:5432/omniagent
QDRANT_URL=http://qdrant:6333
HOST=0.0.0.0
PORT=8080

# Agent / LLM configuration
LLM_PROVIDER=opencode-go
# Agent-level max tokens per response (read by agent/mod.rs)
MAX_TOKENS=8192
# LLM client-level max tokens (read by llm/mod.rs)
LLM_MAX_TOKENS=8192
TEMPERATURE=0.7
SUMMARIZE_AFTER_DAYS=7
MAX_ITERATIONS=60

# Mattermost
MATTERMOST_SITE_URL=https://hermes-app-5.nexuslbs.org
