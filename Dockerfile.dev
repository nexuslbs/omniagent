# syntax=docker/dockerfile:1
# OmniAgent — Development environment image
# Rust toolchain + dev tooling. No code is built here — run builds
# manually via docker compose exec or the scripts/build.py entry point.
FROM rust:1.96.0
WORKDIR /app

# Rust dev components (fast — no compilation, just downloads)
RUN rustup component add rustfmt clippy

# Trust all repos under /opt/workspace (container mounts host git repos)
RUN git config --global --add safe.directory /opt/workspace/omni-stack/.git \
    && git config --global --add safe.directory /opt/workspace/omni-plugins/.git \
    && git config --global --add safe.directory /opt/workspace/omni-dashboard/.git \
    && git config --global --add safe.directory /opt/workspace/omniagent/.git

# Keep the container alive — no code builds here.
# Run builds manually: docker compose exec omniagent cargo build --release -p omniagent
# Or use the build script: docker compose exec omniagent python3 /app/scripts/build.py
CMD exec tail -f /dev/null
