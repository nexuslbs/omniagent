# syntax=docker/dockerfile:1
# OmniAgent — Development image
# Full Rust toolchain for cargo build/check/test with compile-time
# sql_forge! verification against the live postgres DB (via Docker network).
FROM rust:1.96.0
WORKDIR /app

# Rust dev components (fast — no compilation, just downloads)
RUN rustup component add rustfmt clippy

# Trust all repos under /opt/workspace (container mounts host git repos)
RUN git config --global --add safe.directory /opt/workspace/omni-stack/.git \
    && git config --global --add safe.directory /opt/workspace/omni-plugins/.git \
    && git config --global --add safe.directory /opt/workspace/omni-dashboard/.git \
    && git config --global --add safe.directory /opt/workspace/omniagent/.git

# cargo-binstall + cargo-watch (pre-built binaries, no compilation)
RUN curl -fsSLo /tmp/cargo-binstall.tgz \
      "https://github.com/ryankurte/cargo-binstall/releases/latest/download/cargo-binstall-x86_64-unknown-linux-musl.tgz" \
    && tar -xzf /tmp/cargo-binstall.tgz -C /usr/local/cargo/bin/ \
    && rm /tmp/cargo-binstall.tgz \
    && cargo binstall cargo-watch -y --locked 2>&1

# Auto-rebuild and restart on source changes via cargo watch
# Only watches src/ — excludes Cargo.toml, migrations, config files, etc.
# Logs are JSON (set by the app's tracing subscriber) — watch the container logs
# to see build output and agent startup.
CMD ["cargo", "watch", "-w", "src", "-x", "run --release"]
