  "query": "\n        SELECT\n            id, channel_id, next_thread_id, content,\n            COALESCE(TO_CHAR(created_at, 'YYYY-MM-DD\"T\"HH24' || CHR(58) || 'MI' || CHR(58) || 'SS.US\"Z\"'), '') AS \"created_at\"\n        FROM summaries\n        WHERE channel_id = $1\n        ORDER BY id DESC\n        LIMIT $2\n        ",
