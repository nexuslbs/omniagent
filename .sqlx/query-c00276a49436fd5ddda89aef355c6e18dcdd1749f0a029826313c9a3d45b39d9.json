{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT m.id, m.content\n        FROM messages m\n        JOIN threads t ON t.id = m.thread_id\n        WHERE t.channel_id = $1\n          AND m.thread_sequence = 0\n        ORDER BY m.id DESC\n        LIMIT 1\n        ",
