{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT m.id AS msg_id, t.id AS thread_id, t.status\n        FROM messages m\n        JOIN threads t ON t.id = m.thread_id\n        JOIN channels ch ON ch.id = t.channel_id\n        WHERE m.external_id = $1\n          AND m.thread_sequence = 0\n          AND ch.platform = $2\n          AND ch.resource_identifier = $3\n        LIMIT 1\n        ",
