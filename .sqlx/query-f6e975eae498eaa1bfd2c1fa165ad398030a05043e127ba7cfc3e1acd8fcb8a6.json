  "query": "\n        SELECT\n            id, channel_id, subscriber_platform, subscriber_resource,\n            COALESCE(TO_CHAR(created_at, 'YYYY-MM-DD\"T\"HH24' || CHR(58) || 'MI' || CHR(58) || 'SS.US\"Z\"'), '') AS \"created_at\"\n        FROM channel_subscriptions\n        WHERE channel_id = $1\n        ORDER BY id ASC\n        ",
