{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            s.id,\n            s.channel_id,\n            c.name AS channel_name,\n            c.platform,\n            c.resource_identifier\n        FROM channel_subscriptions s\n        JOIN channels c ON c.id = s.channel_id\n        WHERE c.platform = $1\n        ORDER BY c.name\n        ",
