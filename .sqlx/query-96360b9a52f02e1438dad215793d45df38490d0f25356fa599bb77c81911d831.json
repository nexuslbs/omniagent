{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            ts.id,\n            ts.description,\n            ts.status,\n            ts.priority,\n            ts.thread_id,\n            COALESCE(NULLIF(t.cause, ''), t.id::text) AS thread_title,\n            ts.created_at,\n            ts.updated_at\n        FROM thread_subtasks ts\n        JOIN threads t ON t.id = ts.thread_id\n        WHERE t.task_id = $1\n        ORDER BY t.id, ts.priority DESC, ts.id ASC\n        ",
