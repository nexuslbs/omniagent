  "query": "\n        SELECT id, content, role, msg_type\n        FROM messages\n        WHERE thread_id IN (SELECT id FROM threads WHERE channel_id = $1)\n          AND thread_sequence = 0\n        ORDER BY created_at DESC\n        LIMIT $2\n        ",
