{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT m.id, m.role, m.content FROM messages m\n            JOIN threads t ON t.id = m.thread_id\n            WHERE t.channel_id = $1\n              AND m.content ILIKE '%' || $2 || '%'\n            ORDER BY m.created_at DESC\n            LIMIT $3\n            ",
