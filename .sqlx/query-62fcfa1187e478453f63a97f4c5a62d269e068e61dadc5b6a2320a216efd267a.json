  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, kanban_task_id, action, initial_board, final_board,\n               previous_values, created_at::text AS created_at\n        FROM kanban_history\n        WHERE ($1 = '' OR kanban_task_id = $2)\n          AND ($3 = '' OR action = $4)\n        ORDER BY id DESC\n        LIMIT $5 OFFSET $6\n        ",
