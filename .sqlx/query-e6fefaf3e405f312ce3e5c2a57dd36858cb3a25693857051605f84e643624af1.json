{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            d.depends_on_id AS id,\n            t.title,\n            t.status,\n            t.priority,\n            d.created_at\n        FROM kanban_task_dependencies d\n        JOIN kanban_tasks t ON t.id = d.depends_on_id\n        WHERE d.task_id = $1\n        ORDER BY t.priority ASC, t.created_at DESC\n        ",
